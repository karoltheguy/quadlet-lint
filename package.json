{
  "name": "quadlet-lint",
  "version": "0.1.0",
  "description": "Linting for Podman Quadlet unit files, with a Monaco Editor adapter.",
  "keywords": [
    "podman",
    "quadlet",
    "systemd",
    "linter",
    "monaco",
    "monaco-editor"
  ],
  "license": "MIT",
  "type": "module",
  "bin": {
    "quadlet-lint": "bin/quadlet-lint.mjs"
  },
  "files": [
    "dist",
    "bin"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./monaco": {
      "types": "./dist/monaco.d.ts",
      "import": "./dist/monaco.js",
      "require": "./dist/monaco.cjs"
    },
    "./service": {
      "types": "./dist/service.d.ts",
      "import": "./dist/service.js",
      "require": "./dist/service.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "gen:keys": "node scripts/extract-keys.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "vite demo",
    "build:demo": "vite build demo --base=./ --outDir dist-demo",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "package:vscode": "npm --prefix extensions/vscode run build && cd extensions/vscode && npx @vscode/vsce package --no-dependencies"
  },
  "peerDependencies": {
    "monaco-editor": ">=0.34.0"
  },
  "peerDependenciesMeta": {
    "monaco-editor": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@types/vscode": "^1.90.0",
    "monaco-editor": "^0.52.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
