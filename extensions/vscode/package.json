{
  "name": "quadlet-lint-vscode",
  "private": true,
  "version": "0.0.1",
  "publisher": "karoltheguy",
  "displayName": "Quadlet Lint",
  "description": "Linting, completions, hover documentation, and quick fixes for Podman Quadlet unit files.",
  "repository": {
    "type": "git",
    "url": "https://github.com/karoltheguy/quadlet-lint"
  },
  "license": "MIT",
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "main": "./dist/extension.cjs",
  "activationEvents": [
    "onLanguage:quadlet"
  ],
  "contributes": {
    "languages": [
      {
        "id": "quadlet",
        "aliases": [
          "Quadlet"
        ],
        "extensions": [
          ".container",
          ".pod",
          ".network",
          ".volume",
          ".kube",
          ".build",
          ".image",
          ".artifact"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "quadlet",
        "scopeName": "source.quadlet",
        "path": "./syntaxes/quadlet.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "build": "node build.mjs"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "esbuild": "^0.24.0"
  }
}
